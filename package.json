{
  "name": "@vois/webview-bridge",
  "version": "0.1.0",
  "description": "JS → native WebView bridge protocol for Vois / Weila H5 pages (uniBridgeCall).",
  "keywords": [
    "bridge",
    "jsbridge",
    "vois",
    "webview",
    "weila"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./vois": {
      "types": "./dist/vois.d.mts",
      "import": "./dist/vois.mjs",
      "default": "./dist/vois.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "dev:playground": "pnpm --dir playground dev",
    "build:playground": "pnpm --dir playground build",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
