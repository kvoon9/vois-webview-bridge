{
  "name": "@vois/webview-bridge",
  "version": "0.1.0",
  "description": "JS → native WebView bridge protocol for Vois / Weila H5 pages (uniBridgeCall).",
  "keywords": [
    "bridge",
    "jsbridge",
    "vois",
    "webview",
    "weila"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./vois": {
      "types": "./dist/vois.d.mts",
      "import": "./dist/vois.mjs",
      "default": "./dist/vois.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "dev:playground": "pnpm --dir playground dev",
    "build:playground": "pnpm --dir playground build",
    "preview:playground": "pnpm --dir playground preview",
    "docs:dev": "blume dev",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:preview": "blume preview",
    "build:site": "pnpm build:playground && pnpm docs:build",
    "deploy": "pnpm run deploy:playground && pnpm run deploy:docs",
    "deploy:docs": "vpx wrangler pages deploy docs/dist --config wrangler.docs.toml",
    "deploy:playground": "vpx wrangler pages deploy playground/dist --config wrangler.playground.toml",
    "cf:login": "vpx wrangler login",
    "cf:whoami": "vpx wrangler whoami",
    "cf:projects": "vpx wrangler pages project list",
    "cf:deployments:docs": "vpx wrangler pages deployment list --config wrangler.docs.toml",
    "cf:deployments:playground": "vpx wrangler pages deployment list --config wrangler.playground.toml"
  },
  "devDependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@shikijs/twoslash": "^4.3.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "astro": "^7.0.7",
    "blume": "^0.8.0",
    "bumpp": "^11.1.0",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
